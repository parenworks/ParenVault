#!/bin/bash
# ParenVault launcher script
# Usage: ./pv [command]
#   ./pv        - Start TUI (default)
#   ./pv tui    - Start TUI
#   ./pv help   - Show help

export PARENVAULT_DB_PASSWORD="${PARENVAULT_DB_PASSWORD:-b3l0wz3r0}"

case "${1:-tui}" in
  tui)
    dune exec parenvault -- tui
    ;;
  help)
    echo "ParenVault - Personal Knowledge Manager"
    echo ""
    echo "Usage: ./pv [command]"
    echo ""
    echo "Commands:"
    echo "  tui   - Start the terminal UI (default)"
    echo "  help  - Show this help"
    echo ""
    echo "Keyboard shortcuts in TUI:"
    echo "  1     - Dashboard"
    echo "  2     - Tasks"
    echo "  3     - Notes"
    echo "  4     - Calendar"
    echo "  5     - Projects"
    echo "  6     - Contacts"
    echo "  0     - Inbox"
    echo ""
    echo "  j/↓   - Move down"
    echo "  k/↑   - Move up"
    echo "  g     - Go to first item"
    echo "  G     - Go to last item"
    echo "  Enter - Open selected item"
    echo "  n     - Create new item"
    echo "  e     - Edit selected item"
    echo "  x     - Toggle task done/todo"
    echo "  d     - Delete selected item"
    echo "  Esc   - Go back / Cancel"
    echo "  q     - Quit"
    echo ""
    echo "In edit forms:"
    echo "  Tab/↓ - Next field"
    echo "  ↑     - Previous field"
    echo "  Enter - Save"
    echo "  Esc   - Cancel"
    ;;
  *)
    echo "Unknown command: $1"
    echo "Run './pv help' for usage"
    exit 1
    ;;
esac
